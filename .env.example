# Jamal Job Finder - Credentials
# Copy this to .env and fill in real values
# NEVER commit .env to git

# Application email (system-controlled, for sending applications)
APP_EMAIL=your-app-email@gmail.com
APP_EMAIL_PASSWORD=your-gmail-app-password

# Recipient email (who gets fallback notifications)
JAMAL_EMAIL=recipient@gmail.com

# Claude API key (for cover letter generation)
ANTHROPIC_API_KEY=sk-ant-...

# Job board credentials
INDEED_EMAIL=your-app-email@gmail.com
INDEED_PASSWORD=your-password
REED_EMAIL=your-app-email@gmail.com
REED_PASSWORD=your-password
S1JOBS_EMAIL=your-app-email@gmail.com
S1JOBS_PASSWORD=your-password
CATERER_EMAIL=your-app-email@gmail.com
CATERER_PASSWORD=your-password
CVLIBRARY_EMAIL=your-app-email@gmail.com
CVLIBRARY_PASSWORD=your-password
TOTALJOBS_EMAIL=your-app-email@gmail.com
TOTALJOBS_PASSWORD=your-password
